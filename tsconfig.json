{
    "compilerOptions": {
        "target": "ES2023",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "ignoreDeprecations": "6.0",
        "plugins": [
            {
                "name": "next"
            }
        ],
        "baseUrl": ".",
        "paths": {
            // "@/*": ["./src/*"]
            "@/*": ["src/*"],
            "@profiles/*": ["src/app/(dashboard)/profiles/*"],
            "@diagnostics/*": ["src/app/(dashboard)/profiles/diagnostics/*"],
            "@runtime/*": ["src/app/(dashboard)/profiles/runtime/*"],
            "@scenario/*": ["src/app/(dashboard)/profiles/runtime/scenario/*"],
            "@td3q/*": [
                "src/app/(dashboard)/profiles/runtime/scenario/builtins/td3q/*"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "**/*.mts"
    ],
    "exclude": ["node_modules"]
}
